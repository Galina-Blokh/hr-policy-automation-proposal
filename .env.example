# =============================================================================
# HR Policy RAG — Environment Configuration
# Copy this file to `.env` and fill in your API keys. Never commit `.env`.
# =============================================================================

# --- Required: OpenAI (embeddings + primary LLM) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Recommended: Groq (fallback LLM when OpenAI generation fails) ---
GROQ_API_KEY=gsk_your-groq-key

# --- Model selection ---
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# --- Storage paths ---
VECTOR_STORE_PATH=./data/chroma
DATA_DIR=./data

# --- Retrieval tuning ---
TOP_K=5                          # chunks retrieved per query
REFUSAL_THRESHOLD=0.40           # min similarity (0–1) before refusing
CHUNK_SIZE=500                   # tokens per chunk during ingestion
CHUNK_OVERLAP=50                 # token overlap between chunks

# --- Refusal message contact ---
HR_CONTACT_EMAIL=hr@company.com
